---
import { serviceCategories, getCategoryBySlug } from '../../data/services';
import Layout from '../../layouts/Layout.astro';
import { contactInfo } from '../../data/contact';

export function getStaticPaths() {
  return serviceCategories.map((category) => ({
    params: { category: category.slug },
  }));
}

const { category: categorySlug } = Astro.params;
const category = getCategoryBySlug(categorySlug);

if (!category) {
  return Astro.redirect('/services');
}

const siteUrl = 'https://vitriersparis.fr';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${siteUrl}/services` },
    { "@type": "ListItem", "position": 3, "name": category.name, "item": `${siteUrl}/services/${category.slug}` }
  ]
};

const serviceSchemas = category.services.map(service => ({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": service.title,
  "name": service.title,
  "description": service.description.slice(0, 200),
  "provider": { "@id": `${siteUrl}/#organization` },
  "areaServed": { "@type": "State", "name": "Île-de-France" },
  "url": `${siteUrl}/services/${category.slug}`,
  "offers": {
    "@type": "Offer",
    "priceCurrency": "EUR",
    "price": service.price.replace(/[^\d]/g, ''),
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "EUR",
      "price": service.price.replace(/[^\d]/g, ''),
      "description": service.price
    }
  }
}));
---

<Layout
  title={`${category.name} | Vitriers Paris - ${contactInfo.companyName}`}
  description={`${category.description} Intervention sur Paris et toute l'Île-de-France. Devis gratuit, tarifs dès ${(category.services[0]?.price || 'À partir de 60 €').replace(/^À partir de\s*/i, '')}.`}
  canonical={`/services/${category.slug}`}
  jsonLd={[breadcrumbSchema, ...serviceSchemas]}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-600 via-primary-700 to-[#1A2B4A]"></div>
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="absolute bottom-0 left-1/3 w-96 h-64 bg-white/5 rounded-full blur-3xl"></div>

    <div class="relative container-custom section-padding !py-16 md:!py-24">
      <div class="max-w-3xl">
        <nav class="flex items-center gap-2 text-sm text-primary-200 mb-6 flex-wrap" aria-label="Fil d'Ariane" style="animation: fade-in 0.5s ease-out">
          <a href="/" class="hover:text-white transition-colors">Accueil</a>
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <a href="/services" class="hover:text-white transition-colors">Services</a>
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <span class="text-white">{category.name}</span>
        </nav>

        <div class="flex items-start gap-4 mb-6" style="animation: fade-in-up 0.6s ease-out 0.1s both">
          <div class="w-16 h-16 rounded-2xl overflow-hidden shrink-0 border border-white/20">
            <img src={category.image} alt={`${category.name} - vitrier Paris`} class="w-full h-full object-cover" width="64" height="64" />
          </div>
          <div>
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white">{category.name}</h1>
          </div>
        </div>

        <p class="text-lg text-primary-100 leading-relaxed" style="animation: fade-in-up 0.6s ease-out 0.2s both">
          {category.description}
        </p>

        <div class="flex flex-wrap gap-4 mt-6" style="animation: fade-in-up 0.6s ease-out 0.3s both">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/20 rounded-lg text-sm text-white">
            <svg class="w-4 h-4 text-primary-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
            {category.services.length} services disponibles
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/20 rounded-lg text-sm text-white">
            <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            Devis gratuit
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section-padding bg-[#F0F4F8]">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1A2B4A] mb-3">Nos prestations en {category.name.toLowerCase()}</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">Découvrez le détail de chaque service, nos tarifs et contactez-nous pour un devis personnalisé.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {category.services.map((service, index) => (
          <div class:list={['animate-on-scroll hover-lift rounded-2xl overflow-hidden border border-[#DFE6EE] bg-white shadow-sm flex flex-col', `delay-${(index + 1) * 100}`]}>
            <div class="relative h-48 overflow-hidden">
              <img
                src={service.image}
                srcset={`${service.image.replace('w=600', 'w=320').replace('h=400', 'h=213')} 320w, ${service.image} 600w`}
                sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt={`${service.title} - vitrier Paris Île-de-France`}
                class="absolute inset-0 w-full h-full object-cover"
                width="600" height="400" loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#1A2B4A]/60 via-[#1A2B4A]/20 to-transparent"></div>
              <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1.5 rounded-full border border-accent-400/30">
                <span class="text-sm font-bold text-accent-600">{service.price}</span>
              </div>
              <div class="absolute bottom-4 left-4 w-9 h-9 bg-white/20 backdrop-blur-sm rounded-lg flex items-center justify-center border border-white/20">
                <svg class="w-4.5 h-4.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.iconPath} />
                </svg>
              </div>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-lg font-bold text-[#1A2B4A] mb-3">{service.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-6 flex-1">{service.description}</p>
              <div class="space-y-2 pt-4 border-t border-[#DFE6EE]">
                <a href={contactInfo.phoneHref} class="btn-accent w-full text-sm !py-2.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                  Appeler - {contactInfo.phone}
                </a>
                <div class="grid grid-cols-2 gap-2">
                  <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="btn-whatsapp text-sm !py-2.5 !px-3">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WhatsApp
                  </a>
                  <a href="#" class="btn-secondary text-sm !py-2.5 !px-3 service-email-link">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                    Email
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Other Categories -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1A2B4A] mb-3">Découvrez nos autres catégories</h2>
        <p class="text-slate-600">Explorez l'ensemble de nos prestations de vitrerie en Île-de-France.</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-4 max-w-3xl mx-auto">
        {serviceCategories.filter(c => c.slug !== category.slug).map((otherCat, index) => (
          <a href={`/services/${otherCat.slug}`} class:list={['animate-on-scroll hover-lift card-dark rounded-xl p-5 flex items-center gap-4 group', `delay-${(index + 1) * 100}`]}>
            <div class="w-12 h-12 rounded-xl overflow-hidden shrink-0">
              <img src={otherCat.image} alt={`${otherCat.name} - vitrerie Paris`} class="w-full h-full object-cover" width="48" height="48" loading="lazy" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-[#1A2B4A] group-hover:text-primary-500 transition-colors text-sm">{otherCat.name}</h3>
              <p class="text-xs text-slate-500 mt-0.5">{otherCat.services.length} services</p>
            </div>
            <svg class="w-5 h-5 text-slate-400 group-hover:text-primary-500 group-hover:translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script>
    (function(){var u='contact';var d='monartisanidf.fr';document.querySelectorAll('.service-email-link').forEach(function(el){el.href='mai'+'lto:'+u+'@'+d;});})();
  </script>

  <!-- Emergency CTA Banner -->
  <section class="bg-gradient-to-r from-primary-800 via-primary-700 to-primary-800 border-y border-primary-600/20">
    <div class="container-custom px-4 md:px-6 lg:px-8 py-10 md:py-14">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Besoin d'un devis personnalisé ?</h2>
          <p class="text-primary-200">Nos experts sont disponibles pour étudier votre projet et vous proposer la meilleure solution.</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href={contactInfo.phoneHref} class="btn-accent !py-3.5" style="animation: pulse-glow 2s ease-in-out infinite">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            Appeler maintenant
          </a>
          <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="btn-whatsapp !py-3.5">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
