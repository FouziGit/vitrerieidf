---
import { serviceCategories } from '../../data/services';
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { contactInfo } from '../../data/contact';
import { ShaderAnimation } from '../../components/ui/shader-animation';

const siteUrl = 'https://vitriersparis.fr';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${siteUrl}/services` }
  ]
};
---

<Layout
  title="Services de vitrerie Paris & IDF | Vitriers Paris - Artisan Francilien IDF"
  description="Tous nos services de vitrerie en Île-de-France : double vitrage, miroiterie sur mesure, dépannage urgence 24h/24. 9 prestations, tarifs transparents, devis gratuit."
  canonical="/services"
  jsonLd={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <ShaderAnimation client:load />
    <div class="absolute inset-0 bg-[#1A2B4A]/40"></div>

    <div class="relative container-custom section-padding !py-16 md:!py-24 z-10">
      <div class="max-w-3xl">
        <nav class="flex items-center gap-2 text-sm text-primary-200 mb-6" aria-label="Fil d'Ariane" style="animation: fade-in 0.5s ease-out">
          <a href="/" class="hover:text-white transition-colors">Accueil</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <span class="text-white">Services</span>
        </nav>

        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/10 text-white rounded-full text-sm font-medium mb-6 border border-white/20" style="animation: fade-in 0.5s ease-out">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          Catalogue de services
        </span>
        <h1 class="text-4xl md:text-5xl font-black text-white mb-4" style="animation: fade-in-up 0.6s ease-out 0.1s both">
          Nos services de <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-200 to-accent-400">vitrerie</span>
        </h1>
        <p class="text-lg text-primary-100 leading-relaxed" style="animation: fade-in-up 0.6s ease-out 0.2s both">
          Du dépannage d'urgence aux projets de vitrerie sur mesure, découvrez l'ensemble de nos prestations avec des tarifs transparents et compétitifs.
        </p>
      </div>
    </div>
  </section>

  <!-- Category Cards -->
  <section class="section-padding bg-[#F0F4F8]">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-[#1A2B4A] mb-3">Choisissez votre catégorie</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">Sélectionnez un domaine pour découvrir nos prestations détaillées, tarifs et modalités d'intervention.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {serviceCategories.map((category, index) => (
          <a
            href={`/services/${category.slug}`}
            class:list={[
              'animate-on-scroll hover-lift group block rounded-2xl overflow-hidden border border-[#DFE6EE] bg-white shadow-sm transition-all duration-300',
              `delay-${(index + 1) * 100}`
            ]}
          >
            <div class="relative h-52 overflow-hidden">
              <img
                src={category.image}
                alt={category.name}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#1A2B4A]/70 via-[#1A2B4A]/30 to-transparent"></div>
              <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-3 py-1.5 rounded-full border border-white/50">
                <span class="text-xs font-semibold text-[#1A2B4A]">{category.services.length} services</span>
              </div>
              <div class="absolute bottom-4 left-4 w-10 h-10 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center border border-white/20">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={category.iconPath} />
                </svg>
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-[#1A2B4A] mb-2 group-hover:text-primary-500 transition-colors">{category.name}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-4">{category.description}</p>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-1 text-sm font-medium text-primary-500">
                  <span>Voir les services</span>
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-gradient-to-r from-primary-800 via-primary-700 to-primary-800 border-y border-primary-600/20">
    <div class="container-custom px-4 md:px-6 lg:px-8 py-10 md:py-14">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Vous ne trouvez pas ce que vous cherchez ?</h2>
          <p class="text-primary-200">Contactez-nous pour toute demande spécifique. Nos experts vous conseilleront la meilleure solution.</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href="#contact" class="btn-accent !py-3.5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            Demander un devis
          </a>
          <a href={contactInfo.phoneHref} class="btn-secondary !py-3.5 !text-white !border-white/30 hover:!bg-white/10">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            {contactInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <ContactForm />
</Layout>
