---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { contactInfo } from '../data/contact';

const siteUrl = 'https://www.artisan-francilien-idf.fr';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Qui sommes-nous", "item": `${siteUrl}/qui-sommes-nous` }
  ]
};
---

<Layout
  title="Qui sommes-nous | Vitrier Paris & IDF - Artisan Francilien IDF"
  description="Artisan Francilien IDF : entreprise de vitrerie fondée en 2009, basée à Paris. 15+ ans d'expérience, 5 000+ interventions, 8 départements couverts. Garantie décennale."
  canonical="/qui-sommes-nous"
  jsonLd={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="relative bg-dark-950 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.08&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary-500/5 to-transparent"></div>
    <div class="relative container-custom section-padding !py-16 md:!py-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-900/50 text-primary-300 rounded-full text-sm font-medium mb-6 border border-primary-800/50" style="animation: fade-in 0.5s ease-out">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
          À propos
        </span>
        <h1 class="text-4xl md:text-5xl font-black mb-4" style="animation: fade-in-up 0.6s ease-out 0.1s both">Qui sommes-nous ?</h1>
        <p class="text-lg text-gray-300 leading-relaxed" style="animation: fade-in-up 0.6s ease-out 0.2s both">
          <strong class="text-white">Artisan Francilien IDF</strong> est une entreprise de vitrerie fondée en 2009 à Paris. Spécialisée dans le double vitrage, la miroiterie sur mesure et le dépannage d'urgence, elle intervient sur les 8 départements d'Île-de-France avec une équipe de vitriers qualifiés. L'entreprise totalise plus de 5 000 interventions et est couverte par une garantie décennale.
        </p>
      </div>
    </div>
  </section>

  <!-- Notre histoire -->
  <section class="section-padding bg-dark-900">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <h2 class="text-3xl font-bold text-white mb-6">Notre histoire</h2>
          <div class="space-y-4 text-gray-400 leading-relaxed">
            <p>
              Fondée par des artisans vitriers passionnés, <strong class="text-white">Artisan Francilien IDF</strong> est née de la volonté d'offrir un service de vitrerie d'excellence, alliant savoir-faire artisanal et techniques modernes. Notre entreprise s'est construite sur des valeurs simples : la qualité du travail, le respect du client et la réactivité.
            </p>
            <p>
              Au fil des années, nous avons développé une expertise reconnue dans tous les domaines de la vitrerie : du dépannage d'urgence à la réalisation de projets architecturaux complexes. Notre équipe de techniciens qualifiés intervient chaque jour pour sécuriser, isoler et embellir les espaces de vie et de travail de nos clients.
            </p>
            <p>
              Aujourd'hui, Artisan Francilien IDF est un acteur incontournable de la vitrerie en Île-de-France, avec plus de <strong class="text-white">5 000 interventions réalisées</strong> et une clientèle fidèle composée de particuliers, de commerces et d'entreprises.
            </p>
          </div>
        </div>

        <div class="animate-on-scroll delay-200">
          <div class="bg-dark-800 rounded-2xl p-8 border border-white/5">
            <div class="grid grid-cols-2 gap-6">
              <div class="text-center">
                <div class="text-4xl font-black text-accent-400 mb-1">15+</div>
                <div class="text-sm text-gray-400">Années d'expérience</div>
              </div>
              <div class="text-center">
                <div class="text-4xl font-black text-accent-400 mb-1">5000+</div>
                <div class="text-sm text-gray-400">Interventions</div>
              </div>
              <div class="text-center">
                <div class="text-4xl font-black text-accent-400 mb-1">24/7</div>
                <div class="text-sm text-gray-400">Service d'urgence</div>
              </div>
              <div class="text-center">
                <div class="text-4xl font-black text-accent-400 mb-1">8</div>
                <div class="text-sm text-gray-400">Départements couverts</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Nos valeurs -->
  <section class="section-padding bg-dark-800">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-900/50 text-primary-300 rounded-full text-sm font-medium mb-4 border border-primary-800/50">Nos engagements</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Nos valeurs</h2>
        <p class="text-gray-400 max-w-2xl mx-auto">Les principes qui guident chacune de nos interventions et font d'Artisan Francilien IDF un partenaire de confiance.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="animate-on-scroll delay-100 card-dark rounded-2xl p-6 hover-lift">
          <div class="w-14 h-14 bg-primary-500/10 rounded-2xl flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          </div>
          <h3 class="font-bold text-white text-lg mb-2">Réactivité</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Nous comprenons l'urgence de chaque situation. Nos équipes sont mobilisables en moins d'une heure sur Paris et sa proche banlieue, 24 heures sur 24.</p>
        </div>

        <div class="animate-on-scroll delay-200 card-dark rounded-2xl p-6 hover-lift">
          <div class="w-14 h-14 bg-accent-500/10 rounded-2xl flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
          </div>
          <h3 class="font-bold text-white text-lg mb-2">Excellence</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Chaque intervention est réalisée dans les règles de l'art, avec des matériaux certifiés et une finition irréprochable. Nous visons la perfection dans chaque détail.</p>
        </div>

        <div class="animate-on-scroll delay-300 card-dark rounded-2xl p-6 hover-lift">
          <div class="w-14 h-14 bg-primary-500/10 rounded-2xl flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
          </div>
          <h3 class="font-bold text-white text-lg mb-2">Transparence</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Devis détaillé et gratuit avant toute intervention. Aucun frais caché, aucune mauvaise surprise. Le prix annoncé est le prix facturé.</p>
        </div>

        <div class="animate-on-scroll delay-100 card-dark rounded-2xl p-6 hover-lift">
          <div class="w-14 h-14 bg-green-500/10 rounded-2xl flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          </div>
          <h3 class="font-bold text-white text-lg mb-2">Sécurité</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Tous nos vitrages sont conformes aux normes européennes. Nos artisans sont assurés et notre entreprise dispose de la garantie décennale.</p>
        </div>

        <div class="animate-on-scroll delay-200 card-dark rounded-2xl p-6 hover-lift">
          <div class="w-14 h-14 bg-primary-500/10 rounded-2xl flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.893 13.393l-1.135-1.135a2.252 2.252 0 01-.421-.585l-1.08-2.16a.414.414 0 00-.663-.107.827.827 0 01-.812.21l-1.273-.363a.89.89 0 00-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 01-1.81 1.025 1.055 1.055 0 01-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 01-1.383-2.46l.007-.042a2.25 2.25 0 01.29-.787l.09-.15a2.25 2.25 0 012.37-1.048l1.178.236a1.125 1.125 0 001.302-.795l.208-.73a1.125 1.125 0 00-.578-1.315l-.665-.332-.091.091a2.25 2.25 0 01-1.591.659h-.18a.94.94 0 00-.662.274.931.931 0 01-1.458-1.137l1.411-2.353a2.25 2.25 0 00.286-.76m11.928 9.869A9 9 0 008.965 3.525m11.928 9.868A9 9 0 118.965 3.525" /></svg>
          </div>
          <h3 class="font-bold text-white text-lg mb-2">Proximité</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Basés à Paris, nous couvrons l'ensemble de l'Île-de-France. Un seul interlocuteur du devis à la livraison finale pour un suivi personnalisé.</p>
        </div>

        <div class="animate-on-scroll delay-300 card-dark rounded-2xl p-6 hover-lift">
          <div class="w-14 h-14 bg-accent-500/10 rounded-2xl flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>
          </div>
          <h3 class="font-bold text-white text-lg mb-2">Écoresponsabilité</h3>
          <p class="text-sm text-gray-400 leading-relaxed">Nous privilégions les matériaux durables et les solutions d'isolation performantes pour réduire l'empreinte énergétique de votre habitat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Zone d'intervention -->
  <section class="section-padding bg-dark-900">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-10">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-900/50 text-primary-300 rounded-full text-sm font-medium mb-4 border border-primary-800/50">Couverture</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Nos zones d'intervention</h2>
        <p class="text-gray-400 max-w-2xl mx-auto">Nous intervenons sur l'ensemble de l'Île-de-France avec des délais rapides. Projets nationaux sur demande.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {[
          { dept: '75', name: 'Paris', time: '< 1h' },
          { dept: '92', name: 'Hauts-de-Seine', time: '< 1h' },
          { dept: '93', name: 'Seine-Saint-Denis', time: '< 1h' },
          { dept: '94', name: 'Val-de-Marne', time: '< 1h' },
          { dept: '91', name: 'Essonne', time: '< 2h' },
          { dept: '95', name: "Val-d'Oise", time: '< 2h' },
          { dept: '78', name: 'Yvelines', time: '< 2h' },
          { dept: '77', name: 'Seine-et-Marne', time: '< 2h' },
        ].map((zone, i) => (
          <div class:list={['animate-on-scroll card-dark rounded-xl p-4 flex items-center gap-3', `delay-${Math.min((i + 1) * 100, 500)}`]}>
            <div class="w-12 h-12 bg-primary-500/20 text-primary-300 rounded-xl flex items-center justify-center font-bold text-sm shrink-0">
              {zone.dept}
            </div>
            <div>
              <div class="font-medium text-white text-sm">{zone.name}</div>
              <div class="text-xs text-accent-400 font-medium">{zone.time}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="animate-on-scroll text-center mt-8">
        <p class="text-sm text-gray-500">Intervention sur toute la France métropolitaine pour les projets d'envergure.</p>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <ContactForm />
</Layout>
