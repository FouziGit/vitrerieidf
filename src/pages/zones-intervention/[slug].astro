---
import Layout from '../../layouts/Layout.astro';
import { contactInfo } from '../../data/contact';
import { serviceCategories } from '../../data/services';
import { getAllCities, getCityBySlug, getDepartmentByCode, departments, generateSEOContent, getInterventionTime } from '../../data/cities';

export function getStaticPaths() {
  return getAllCities().map((city) => ({
    params: { slug: city.slug },
  }));
}

const { slug } = Astro.params;
const city = getCityBySlug(slug);

if (!city) {
  return Astro.redirect('/zones-intervention');
}

const dept = getDepartmentByCode(city.deptCode)!;
const siteUrl = 'https://vitriersparis.fr';
const interventionTime = getInterventionTime(city.deptCode);
const seoContent = generateSEOContent(city.name, city.zip, city.deptName, city.deptCode);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Zones d'intervention", "item": `${siteUrl}/zones-intervention` },
    { "@type": "ListItem", "position": 3, "name": city.deptName, "item": `${siteUrl}/zones-intervention` },
    { "@type": "ListItem", "position": 4, "name": city.name, "item": `${siteUrl}/zones-intervention/${city.slug}` },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Vitrerie",
  "name": `Vitrier ${city.name}`,
  "description": `Service de vitrerie professionnel à ${city.name} (${city.zip}). Double vitrage, miroiterie, dépannage urgence 24h/24.`,
  "provider": { "@id": `${siteUrl}/#organization` },
  "areaServed": {
    "@type": "City",
    "name": city.name,
    "containedInPlace": {
      "@type": "AdministrativeArea",
      "name": city.deptName,
    },
  },
  "availableChannel": {
    "@type": "ServiceChannel",
    "serviceUrl": `${siteUrl}/zones-intervention/${city.slug}`,
    "servicePhone": "+33765822626",
  },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "EUR",
    "lowPrice": "60",
    "highPrice": "1290",
    "offerCount": "32",
  },
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Quel est le délai d'intervention d'un vitrier à ${city.name} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Nos vitriers interviennent à ${city.name} (${city.zip}) en moins de ${interventionTime}. Notre service d'urgence est disponible 24h/24 et 7j/7 pour toutes les urgences vitrage.`,
      },
    },
    {
      "@type": "Question",
      "name": `Combien coûte un remplacement de double vitrage à ${city.name} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Le remplacement de double vitrage à ${city.name} démarre à partir de 180€ TTC, fourniture et pose comprises. Le tarif varie selon les dimensions, le type de vitrage et l'accessibilité. Devis gratuit et sans engagement.`,
      },
    },
    {
      "@type": "Question",
      "name": `Intervenez-vous en urgence la nuit et le week-end à ${city.name} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Oui, notre service d'urgence vitrier couvre ${city.name} et tout le département ${city.deptName} (${city.deptCode}) 24h/24, 7j/7, y compris les nuits, week-ends et jours fériés.`,
      },
    },
    {
      "@type": "Question",
      "name": `Vos interventions à ${city.name} sont-elles prises en charge par l'assurance ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Oui, la plupart de nos interventions d'urgence à ${city.name} sont couvertes par les assurances habitation. Nous travaillons en tiers payant avec les principaux assureurs et vous accompagnons dans vos démarches.`,
      },
    },
    {
      "@type": "Question",
      "name": `Quels services de vitrerie proposez-vous à ${city.name} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `À ${city.name}, nous proposons : remplacement de double/triple vitrage, miroiterie sur mesure (miroirs, crédences, cloisons atelier), dépannage urgence 24h/24, vitrerie commerciale (vitrines, portes Securit) et pose/réparation de fenêtres PVC et aluminium.`,
      },
    },
  ],
};

const nearbyDepts = departments.filter((d) => d.code !== city.deptCode).slice(0, 3);
const sameDeptCities = dept.cities.filter((c) => c.slug !== city.slug).slice(0, 8);
---

<Layout
  title={`Vitrier ${city.name} (${city.zip}) | Dépannage & Vitrerie 24h/24 - Artisan Francilien IDF`}
  description={`Vitrier professionnel à ${city.name} (${city.zip}). Remplacement double vitrage, miroiterie sur mesure, dépannage urgence 24h/24. Intervention en ${interventionTime}. Devis gratuit.`}
  canonical={`/zones-intervention/${city.slug}`}
  jsonLd={[breadcrumbSchema, serviceSchema, faqSchema]}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-600 via-primary-700 to-[#1A2B4A]"></div>
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="absolute bottom-0 right-1/4 w-96 h-64 bg-accent-500/5 rounded-full blur-3xl"></div>

    <div class="relative container-custom section-padding !py-16 md:!py-24">
      <div class="max-w-3xl">
        <nav class="flex items-center gap-2 text-sm text-primary-200 mb-6 flex-wrap" aria-label="Fil d'Ariane" style="animation: fade-in 0.5s ease-out">
          <a href="/" class="hover:text-white transition-colors">Accueil</a>
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <a href="/zones-intervention" class="hover:text-white transition-colors">Zones d'intervention</a>
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <span class="text-white">{city.name}</span>
        </nav>

        <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-4" style="animation: fade-in-up 0.6s ease-out 0.1s both">
          Vitrier {city.name} : intervention en {interventionTime}
        </h1>

        <p class="text-lg text-primary-100 leading-relaxed mb-6" style="animation: fade-in-up 0.6s ease-out 0.2s both">
          Votre vitrier professionnel à {city.name} ({city.zip}), {city.deptName}. Remplacement de double vitrage, miroiterie sur mesure et dépannage d'urgence 24h/24. Devis gratuit et intervention rapide.
        </p>

        <div class="flex flex-wrap gap-3 mb-8" style="animation: fade-in-up 0.6s ease-out 0.3s both">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/20 rounded-lg text-sm text-white">
            <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            {interventionTime}
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/20 rounded-lg text-sm text-white">
            <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            24h/24 - 7j/7
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/20 rounded-lg text-sm text-white">
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            4.8/5 - 247 avis
          </div>
        </div>

        <div class="flex flex-wrap gap-3" style="animation: fade-in-up 0.6s ease-out 0.4s both">
          <a href={contactInfo.phoneHref} class="btn-accent !py-3.5" style="animation: pulse-glow 2s ease-in-out infinite">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            Appeler - {contactInfo.phone}
          </a>
          <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="btn-whatsapp !py-3.5">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Badges -->
  <section class="bg-white border-b border-[#DFE6EE]">
    <div class="container-custom px-4 md:px-6 lg:px-8 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="flex items-center gap-3 p-3 rounded-xl bg-[#F0F4F8]">
          <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          </div>
          <div>
            <p class="text-xs font-semibold text-[#1A2B4A]">Agréé Assurances</p>
            <p class="text-xs text-slate-500">Tiers payant</p>
          </div>
        </div>
        <div class="flex items-center gap-3 p-3 rounded-xl bg-[#F0F4F8]">
          <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
          </div>
          <div>
            <p class="text-xs font-semibold text-[#1A2B4A]">Tarifs transparents</p>
            <p class="text-xs text-slate-500">Devis gratuit</p>
          </div>
        </div>
        <div class="flex items-center gap-3 p-3 rounded-xl bg-[#F0F4F8]">
          <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <p class="text-xs font-semibold text-[#1A2B4A]">Intervention 24h/7j</p>
            <p class="text-xs text-slate-500">Urgences vitrage</p>
          </div>
        </div>
        <div class="flex items-center gap-3 p-3 rounded-xl bg-[#F0F4F8]">
          <div class="w-10 h-10 rounded-lg bg-primary-100 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>
          </div>
          <div>
            <p class="text-xs font-semibold text-[#1A2B4A]">Artisan certifié</p>
            <p class="text-xs text-slate-500">Garantie décennale</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO Content Section -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h2 class="animate-on-scroll text-2xl md:text-3xl font-bold text-[#1A2B4A] mb-8">Votre vitrier à {city.name} ({city.zip})</h2>
        <div class="space-y-6">
          {seoContent.map((paragraph, i) => (
            <p class:list={["animate-on-scroll text-slate-600 leading-relaxed text-base", `delay-${(i + 1) * 100}`]}>
              {paragraph}
            </p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="section-padding bg-[#F0F4F8]">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1A2B4A] mb-3">Nos services de vitrerie à {city.name}</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">Découvrez l'ensemble de nos prestations disponibles à {city.name} et dans le {city.deptName}.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {serviceCategories.map((cat, index) => (
          <a href={`/services/${cat.slug}`} class:list={["animate-on-scroll hover-lift group rounded-2xl overflow-hidden border border-[#DFE6EE] bg-white shadow-sm", `delay-${(index + 1) * 100}`]}>
            <div class="relative h-40 overflow-hidden">
              <img
                src={cat.image}
                alt={`${cat.name} à ${city.name}`}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="800" height="500" loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#1A2B4A]/70 via-[#1A2B4A]/20 to-transparent"></div>
              <div class="absolute bottom-3 left-4">
                <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-white/90 backdrop-blur-sm rounded-full text-xs font-semibold text-primary-700">{cat.services.length} services</span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-[#1A2B4A] mb-2 group-hover:text-primary-600 transition-colors">{cat.name}</h3>
              <p class="text-sm text-slate-600 line-clamp-2">{cat.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <div class="animate-on-scroll text-center mb-10">
          <h2 class="text-2xl md:text-3xl font-bold text-[#1A2B4A] mb-3">Questions fréquentes - Vitrier {city.name}</h2>
          <p class="text-slate-600">Trouvez les réponses à vos questions sur nos services de vitrerie à {city.name}.</p>
        </div>

        <div class="space-y-3">
          <div class="animate-on-scroll delay-100 faq-item border border-[#DFE6EE] rounded-xl overflow-hidden">
            <button class="faq-question w-full flex items-center justify-between p-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-semibold text-[#1A2B4A] pr-4">Quel est le délai d'intervention d'un vitrier à {city.name} ?</span>
              <svg class="faq-icon w-5 h-5 text-primary-500 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-answer hidden px-5 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">Nos vitriers interviennent à {city.name} ({city.zip}) en moins de {interventionTime}. Notre service d'urgence est disponible 24h/24 et 7j/7, y compris les nuits, week-ends et jours fériés. Pour les interventions programmées, nous proposons des rendez-vous à votre convenance.</p>
            </div>
          </div>

          <div class="animate-on-scroll delay-200 faq-item border border-[#DFE6EE] rounded-xl overflow-hidden">
            <button class="faq-question w-full flex items-center justify-between p-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-semibold text-[#1A2B4A] pr-4">Combien coûte un remplacement de double vitrage à {city.name} ?</span>
              <svg class="faq-icon w-5 h-5 text-primary-500 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-answer hidden px-5 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">Le remplacement de double vitrage à {city.name} démarre à partir de 180€ TTC, fourniture et pose comprises. Le tarif exact dépend des dimensions du vitrage, du type choisi (standard, ITR, feuilleté, phonique) et de l'accessibilité. Nous vous remettons un devis gratuit et détaillé avant toute intervention.</p>
            </div>
          </div>

          <div class="animate-on-scroll delay-300 faq-item border border-[#DFE6EE] rounded-xl overflow-hidden">
            <button class="faq-question w-full flex items-center justify-between p-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-semibold text-[#1A2B4A] pr-4">Intervenez-vous en urgence la nuit et le week-end à {city.name} ?</span>
              <svg class="faq-icon w-5 h-5 text-primary-500 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-answer hidden px-5 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">Oui, notre service d'urgence vitrier couvre {city.name} et tout le département {city.deptName} ({city.deptCode}) 24h/24, 7j/7, y compris les nuits, week-ends et jours fériés. Bris de glace, cambriolage, intempéries : appelez-nous pour une prise en charge immédiate.</p>
            </div>
          </div>

          <div class="animate-on-scroll delay-400 faq-item border border-[#DFE6EE] rounded-xl overflow-hidden">
            <button class="faq-question w-full flex items-center justify-between p-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-semibold text-[#1A2B4A] pr-4">Vos interventions à {city.name} sont-elles prises en charge par l'assurance ?</span>
              <svg class="faq-icon w-5 h-5 text-primary-500 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-answer hidden px-5 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">Oui, la plupart de nos interventions d'urgence à {city.name} sont couvertes par les assurances habitation et multirisque professionnel. Nous travaillons en tiers payant avec AXA, MAIF, Groupama, Allianz, MMA et la plupart des assureurs, vous évitant toute avance de frais.</p>
            </div>
          </div>

          <div class="animate-on-scroll delay-500 faq-item border border-[#DFE6EE] rounded-xl overflow-hidden">
            <button class="faq-question w-full flex items-center justify-between p-5 text-left hover:bg-slate-50 transition-colors" aria-expanded="false">
              <span class="font-semibold text-[#1A2B4A] pr-4">Quels services de vitrerie proposez-vous à {city.name} ?</span>
              <svg class="faq-icon w-5 h-5 text-primary-500 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-answer hidden px-5 pb-5">
              <p class="text-slate-600 text-sm leading-relaxed">À {city.name}, nous proposons une gamme complète de services : remplacement de double et triple vitrage, miroiterie sur mesure (miroirs, crédences en verre, cloisons atelier), dépannage urgence 24h/24, vitrerie commerciale (vitrines, portes Securit), et pose ou réparation de fenêtres PVC et aluminium.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Nearby Cities -->
  {sameDeptCities.length > 0 && (
    <section class="section-padding bg-[#F0F4F8]">
      <div class="container-custom">
        <div class="animate-on-scroll text-center mb-8">
          <h2 class="text-2xl md:text-3xl font-bold text-[#1A2B4A] mb-3">Vitrier dans les villes proches de {city.name}</h2>
          <p class="text-slate-600">Nous intervenons également dans ces communes du {city.deptName} ({city.deptCode}).</p>
        </div>
        <div class="flex flex-wrap justify-center gap-2 max-w-4xl mx-auto">
          {sameDeptCities.map((nearby) => (
            <a
              href={`/zones-intervention/${nearby.slug}`}
              class="inline-flex items-center gap-1.5 px-4 py-2 bg-white hover:bg-primary-50 border border-[#DFE6EE] hover:border-primary-300 rounded-lg text-sm text-slate-700 hover:text-primary-700 transition-all duration-200"
            >
              <svg class="w-3.5 h-3.5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
              Vitrier {nearby.name}
            </a>
          ))}
          <a href="/zones-intervention" class="inline-flex items-center gap-1.5 px-4 py-2 bg-primary-50 border border-primary-200 rounded-lg text-sm font-medium text-primary-700 hover:bg-primary-100 transition-colors">
            Voir toutes les zones
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Emergency CTA Banner -->
  <section class="bg-gradient-to-r from-primary-800 via-primary-700 to-primary-800 border-y border-primary-600/20">
    <div class="container-custom px-4 md:px-6 lg:px-8 py-10 md:py-14">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Besoin d'un vitrier à {city.name} ?</h2>
          <p class="text-primary-200">Intervention en {interventionTime}, devis gratuit et transparent. Appelez-nous maintenant.</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href={contactInfo.phoneHref} class="btn-accent !py-3.5" style="animation: pulse-glow 2s ease-in-out infinite">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            Appeler maintenant
          </a>
          <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="btn-whatsapp !py-3.5">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll('.faq-question').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const answer = item?.querySelector('.faq-answer');
        const icon = btn.querySelector('.faq-icon');
        const isOpen = !answer?.classList.contains('hidden');

        document.querySelectorAll('.faq-item').forEach((other) => {
          other.querySelector('.faq-answer')?.classList.add('hidden');
          other.querySelector('.faq-question')?.setAttribute('aria-expanded', 'false');
          other.querySelector('.faq-icon')?.classList.remove('rotate-180');
        });

        if (!isOpen && answer) {
          answer.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
          icon?.classList.add('rotate-180');
        }
      });
    });
  </script>
</Layout>
