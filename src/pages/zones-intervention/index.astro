---
import Layout from '../../layouts/Layout.astro';
import { contactInfo } from '../../data/contact';
import { departments } from '../../data/cities';

const siteUrl = 'https://vitriersparis.fr';
const totalCities = departments.reduce((sum, d) => sum + d.cities.length, 0);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Zones d'intervention", "item": `${siteUrl}/zones-intervention` },
  ],
};

const displayOrder = ["75", "92", "93", "94", "77", "78", "91", "95"];
const sortedDepartments = displayOrder.map((code) => departments.find((d) => d.code === code)!);
---

<Layout
  title="Zones d'intervention | Vitrier Paris & Île-de-France - Artisan Francilien IDF"
  description={`Vitrier professionnel intervenant dans ${totalCities} villes d'Île-de-France. Paris et 8 départements : 75, 77, 78, 91, 92, 93, 94, 95. Intervention rapide, devis gratuit.`}
  canonical="/zones-intervention"
  jsonLd={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-600 via-primary-700 to-[#1A2B4A]"></div>
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;0.15&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="absolute bottom-0 left-1/3 w-96 h-64 bg-white/5 rounded-full blur-3xl"></div>

    <div class="relative container-custom section-padding !py-16 md:!py-24">
      <div class="max-w-3xl">
        <nav class="flex items-center gap-2 text-sm text-primary-200 mb-6 flex-wrap" aria-label="Fil d'Ariane" style="animation: fade-in 0.5s ease-out">
          <a href="/" class="hover:text-white transition-colors">Accueil</a>
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          <span class="text-white">Zones d'intervention</span>
        </nav>

        <div class="flex items-start gap-4 mb-6" style="animation: fade-in-up 0.6s ease-out 0.1s both">
          <div class="w-16 h-16 rounded-2xl bg-white/10 border border-white/20 flex items-center justify-center shrink-0">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          </div>
          <div>
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white">Vitrier de proximité en Île-de-France</h1>
          </div>
        </div>

        <p class="text-lg text-primary-100 leading-relaxed" style="animation: fade-in-up 0.6s ease-out 0.2s both">
          Artisan Francilien IDF intervient dans {totalCities} villes d'Île-de-France pour tous vos besoins en vitrerie, miroiterie et dépannage de vitrage. Remplacement de double vitrage, pose de miroirs sur mesure, urgence bris de glace : nos artisans qualifiés se déplacent rapidement dans votre commune.
        </p>

        <div class="flex flex-wrap gap-4 mt-6" style="animation: fade-in-up 0.6s ease-out 0.3s both">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/20 rounded-lg text-sm text-white">
            <svg class="w-4 h-4 text-primary-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
            8 départements couverts
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/20 rounded-lg text-sm text-white">
            <svg class="w-4 h-4 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            {totalCities} villes desservies
          </div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 border border-white/20 rounded-lg text-sm text-white">
            <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Intervention rapide 24h/7j
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Authority Content -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto animate-on-scroll">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1A2B4A] mb-6 text-center">Nos zones d'intervention en Île-de-France</h2>
        <div class="prose prose-lg text-slate-600 max-w-none text-center">
          <p>
            Artisan Francilien IDF est votre vitrier de proximité, intervenant sur l'ensemble de la région Île-de-France. Spécialistes du remplacement de double vitrage, de la miroiterie sur mesure et du dépannage d'urgence 24h/24, nos artisans qualifiés couvrent Paris et les 7 départements de la petite et grande couronne. Chaque intervention est réalisée avec des matériaux certifiés et bénéficie de notre garantie décennale.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Department Grid -->
  <section class="section-padding bg-[#F0F4F8]">
    <div class="container-custom">
      <div class="grid md:grid-cols-2 gap-6">
        {sortedDepartments.map((dept, index) => (
          <div class:list={["animate-on-scroll rounded-2xl overflow-hidden border border-[#DFE6EE] bg-white shadow-sm", `delay-${(index + 1) * 100}`]}>
            <div class="bg-gradient-to-r from-primary-600 to-primary-700 px-6 py-4 flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center shrink-0">
                <span class="text-xl font-black text-white">{dept.code}</span>
              </div>
              <div>
                <h3 class="text-lg font-bold text-white">{dept.name}</h3>
                <p class="text-sm text-primary-200">{dept.cities.length} villes couvertes</p>
              </div>
            </div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2">
                {dept.cities.map((city) => (
                  <a
                    href={`/zones-intervention/${city.slug}`}
                    class="inline-flex items-center gap-1 px-3 py-1.5 bg-[#F0F4F8] hover:bg-primary-50 border border-[#DFE6EE] hover:border-primary-300 rounded-lg text-sm text-slate-700 hover:text-primary-700 transition-all duration-200"
                  >
                    {city.name}
                    <span class="text-xs text-slate-400">({city.zip})</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-[#1A2B4A] mb-3">Pourquoi choisir Artisan Francilien IDF ?</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">Un service de vitrerie professionnel, rapide et transparent sur toute l'Île-de-France.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div class="animate-on-scroll delay-100 text-center p-6">
          <div class="w-14 h-14 rounded-2xl bg-primary-50 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          </div>
          <h3 class="font-bold text-[#1A2B4A] mb-2">Intervention rapide</h3>
          <p class="text-sm text-slate-600">30 min sur Paris, 45 min en petite couronne, 1h en grande couronne.</p>
        </div>
        <div class="animate-on-scroll delay-200 text-center p-6">
          <div class="w-14 h-14 rounded-2xl bg-primary-50 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          </div>
          <h3 class="font-bold text-[#1A2B4A] mb-2">Garantie qualité</h3>
          <p class="text-sm text-slate-600">Matériaux certifiés, garantie décennale et conformité aux normes européennes.</p>
        </div>
        <div class="animate-on-scroll delay-300 text-center p-6">
          <div class="w-14 h-14 rounded-2xl bg-primary-50 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
          </div>
          <h3 class="font-bold text-[#1A2B4A] mb-2">Tarifs transparents</h3>
          <p class="text-sm text-slate-600">Devis gratuit et détaillé avant intervention. Aucun frais caché.</p>
        </div>
        <div class="animate-on-scroll delay-400 text-center p-6">
          <div class="w-14 h-14 rounded-2xl bg-primary-50 flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>
          </div>
          <h3 class="font-bold text-[#1A2B4A] mb-2">Artisans certifiés</h3>
          <p class="text-sm text-slate-600">Plus de 15 ans d'expérience et des artisans formés aux dernières techniques.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Emergency CTA Banner -->
  <section class="bg-gradient-to-r from-primary-800 via-primary-700 to-primary-800 border-y border-primary-600/20">
    <div class="container-custom px-4 md:px-6 lg:px-8 py-10 md:py-14">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Besoin d'un vitrier en urgence ?</h2>
          <p class="text-primary-200">Nos artisans interviennent rapidement dans toute l'Île-de-France, 24h/24 et 7j/7.</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
          <a href={contactInfo.phoneHref} class="btn-accent !py-3.5" style="animation: pulse-glow 2s ease-in-out infinite">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            Appeler maintenant
          </a>
          <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="btn-whatsapp !py-3.5">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
