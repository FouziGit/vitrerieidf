---
import Layout from '../layouts/Layout.astro';
import { contactInfo } from '../data/contact';
---

<Layout
  title="Page introuvable | Artisan Francilien IDF - Vitrier Paris & IDF"
  description="La page que vous recherchez n'existe pas. Retrouvez nos services de vitrerie, miroiterie et dépannage urgence en Île-de-France."
  canonical="/404"
>
  <section class="section-padding bg-dark-900 min-h-[60vh] flex items-center">
    <div class="container-custom text-center">
      <div class="max-w-lg mx-auto">
        <div class="text-8xl font-black text-primary-400/20 mb-4">404</div>
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Page introuvable</h1>
        <p class="text-gray-400 mb-8 leading-relaxed">
          La page que vous recherchez n'existe pas ou a été déplacée. Retrouvez nos services ci-dessous.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/" class="btn-accent">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
            Retour à l'accueil
          </a>
          <a href="/services" class="btn-secondary">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
            Nos services
          </a>
          <a href={contactInfo.phoneHref} class="btn-primary">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            {contactInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
