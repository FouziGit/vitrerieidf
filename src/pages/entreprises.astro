---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { contactInfo } from '../data/contact';

const siteUrl = 'https://www.artisan-francilien-idf.fr';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Entreprises", "item": `${siteUrl}/entreprises` }
  ]
};
---

<Layout
  title="Vitrerie professionnelle entreprises IDF | Artisan Francilien IDF"
  description="Solutions de vitrerie pour entreprises, commerces et syndics en Île-de-France. Contrats-cadres, tarifs préférentiels, interlocuteur dédié. Devis B2B sous 24h."
  canonical="/entreprises"
  jsonLd={breadcrumbSchema}
>
  <!-- Hero -->
  <section class="relative bg-dark-950 text-white overflow-hidden">
    <!-- Background image -->
    <img
      src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1920&h=1080&fit=crop&q=80"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <!-- Dark overlay for readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-dark-950/95 via-dark-950/85 to-dark-950/70"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-dark-950 via-transparent to-dark-950/50"></div>
    <!-- Glow effects -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="relative container-custom section-padding !py-16 md:!py-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-accent-500/10 text-accent-300 rounded-full text-sm font-medium mb-6 border border-accent-500/20" style="animation: fade-in 0.5s ease-out">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" /></svg>
          Solutions B2B
        </span>
        <h1 class="text-4xl md:text-5xl font-black mb-4" style="animation: fade-in-up 0.6s ease-out 0.1s both">Solutions vitrerie pour <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-300 to-accent-400">professionnels</span></h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-8" style="animation: fade-in-up 0.6s ease-out 0.2s both">
          Artisan Francilien IDF propose des solutions de vitrerie dédiées aux professionnels : entreprises, commerces, syndics de copropriété et acteurs du BTP. L'offre B2B comprend des tarifs préférentiels, un interlocuteur unique, une facturation adaptée (paiement à 30 jours) et des interventions en dehors des heures ouvrées.
        </p>
        <div class="flex flex-wrap gap-3" style="animation: fade-in-up 0.6s ease-out 0.3s both">
          <a href="#contact" class="btn-accent text-base">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            Demander un devis B2B
          </a>
          <a href={contactInfo.phoneHref} class="inline-flex items-center gap-2 px-6 py-3.5 border-2 border-white/20 text-white font-semibold rounded-xl hover:bg-white/5 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            {contactInfo.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Nos clients professionnels -->
  <section class="section-padding bg-dark-900">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-900/50 text-primary-300 rounded-full text-sm font-medium mb-4 border border-primary-800/50">Nos clients</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Nous accompagnons tous les professionnels</h2>
        <p class="text-gray-400 max-w-2xl mx-auto">Quel que soit votre secteur d'activité, Artisan Francilien IDF propose des solutions adaptées à vos besoins spécifiques.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', title: 'Entreprises & bureaux', desc: 'Cloisons vitrées, vitrages de sécurité, remplacement de fenêtres pour vos locaux professionnels. Intervention hors heures ouvrées possible.' },
          { icon: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z', title: 'Commerces & restaurants', desc: 'Installation et remplacement de vitrines, devantures sécurisées, vitrages anti-effraction. Urgence 24h/24 pour protéger votre activité.' },
          { icon: 'M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z', title: 'BTP & construction', desc: 'Fourniture et pose de vitrages pour chantiers neufs et rénovations. Partenariat flexible, livraison sur chantier et gros volumes.' },
          { icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', title: 'Syndics & copropriétés', desc: "Contrats d'entretien, remplacement de vitrages dans les parties communes, mise en conformité et rénovation énergétique." },
          { icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z', title: 'Hôtellerie & restauration', desc: 'Solutions haut de gamme : parois de douche, miroirs, vitrages acoustiques et décoratifs pour vos établissements.' },
          { icon: 'M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342', title: 'Collectivités & santé', desc: 'Vitrages de sécurité, cloisons vitrées pour hôpitaux, cliniques et établissements publics. Conformité aux normes ERP.' },
        ].map((item, i) => (
          <div class:list={['animate-on-scroll card-dark rounded-2xl p-6 hover-lift', `delay-${Math.min((i + 1) * 100, 500)}`]}>
            <div class="w-14 h-14 bg-primary-500/10 rounded-2xl flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} /></svg>
            </div>
            <h3 class="font-bold text-white text-lg mb-2">{item.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Notre processus B2B -->
  <section class="section-padding bg-dark-800">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-accent-500/10 text-accent-300 rounded-full text-sm font-medium mb-4 border border-accent-500/20">Processus</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Notre accompagnement projet</h2>
        <p class="text-gray-400 max-w-2xl mx-auto">Un processus structuré pour garantir la réussite de vos projets de vitrerie, du premier contact à la réception finale.</p>
      </div>

      <div class="grid md:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {[
          { step: '01', title: 'Prise de contact', desc: 'Échange sur vos besoins, contraintes et délais. Premier conseil et orientation.' },
          { step: '02', title: 'Visite technique', desc: 'Déplacement gratuit sur site. Prise de mesures, diagnostic et recommandations.' },
          { step: '03', title: 'Devis détaillé', desc: 'Proposition chiffrée complète, transparente et adaptée à votre budget.' },
          { step: '04', title: 'Réalisation & livraison', desc: 'Exécution soignée, respect des délais et réception avec PV de conformité.' },
        ].map((item, i) => (
          <div class:list={['animate-on-scroll text-center', `delay-${(i + 1) * 100}`]}>
            <div class="w-16 h-16 bg-gradient-to-br from-accent-500 to-accent-600 text-dark-950 rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-black">
              {item.step}
            </div>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-sm text-gray-400">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Avantages B2B -->
  <section class="section-padding bg-dark-900">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <h2 class="text-3xl font-bold text-white mb-6">Pourquoi les professionnels nous choisissent</h2>
          <div class="space-y-4">
            {[
              { title: 'Tarifs préférentiels', desc: 'Grilles tarifaires négociées pour les volumes importants et les contrats récurrents.' },
              { title: 'Interlocuteur dédié', desc: 'Un chargé de projet unique vous accompagne du devis à la réception du chantier.' },
              { title: 'Flexibilité horaire', desc: 'Interventions en dehors des heures ouvrées, le week-end ou la nuit pour ne pas perturber votre activité.' },
              { title: 'Facturation adaptée', desc: 'Paiement à 30 jours, facturation par lot, devis groupés. Nous nous adaptons à vos processus.' },
              { title: 'Garantie décennale', desc: 'Assurance responsabilité civile professionnelle et garantie décennale sur toutes nos prestations.' },
            ].map((item) => (
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 bg-accent-500/20 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </div>
                <div>
                  <h4 class="font-semibold text-white">{item.title}</h4>
                  <p class="text-sm text-gray-400">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="animate-on-scroll delay-200 bg-gradient-to-br from-primary-600/20 to-accent-500/10 rounded-2xl p-8 border border-white/5">
          <h3 class="text-2xl font-bold text-white mb-4">Besoin d'un devis personnalisé ?</h3>
          <p class="text-gray-300 mb-6">Nos experts B2B vous répondent sous 24h avec une proposition adaptée à votre projet et votre budget.</p>
          <div class="space-y-3">
            <a href="#contact" class="btn-accent w-full text-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              Demander un devis B2B
            </a>
            <a href={contactInfo.phoneHref} class="inline-flex items-center gap-2 w-full px-6 py-3.5 border-2 border-white/20 text-white font-semibold rounded-xl hover:bg-white/5 transition-all text-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Appeler : {contactInfo.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <ContactForm />
</Layout>
