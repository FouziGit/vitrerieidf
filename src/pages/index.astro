---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQ from '../components/FAQ.astro';
import { contactInfo } from '../data/contact';
import { serviceCategories } from '../data/services';

const siteUrl = 'https://vitriersparis.fr';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": siteUrl }
  ]
};

const serviceSchemas = serviceCategories.map(cat => ({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": cat.name,
  "name": cat.name,
  "description": cat.description,
  "provider": { "@id": `${siteUrl}/#organization` },
  "areaServed": { "@type": "State", "name": "Île-de-France" },
  "url": `${siteUrl}/services/${cat.slug}`,
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": cat.name,
    "itemListElement": cat.services.map(s => ({
      "@type": "Offer",
      "itemOffered": { "@type": "Service", "name": s.title, "description": s.description.slice(0, 160) }
    }))
  }
}));
---

<Layout
  title="Vitrier Paris | Vitrerie & Dépannage Vitrage 24h/24 - Artisan Francilien IDF"
  description="Services de vitrerie à Paris et en Île-de-France : double vitrage, miroiterie sur mesure, dépannage urgence 24h/24. Intervention rapide, devis gratuit."
  canonical="/"
  jsonLd={[breadcrumbSchema, ...serviceSchemas]}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <!-- Background image -->
    <img
      src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1200&h=675&fit=crop&q=80&fm=webp"
      srcset="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=640&h=360&fit=crop&q=75&fm=webp 640w, https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1024&h=576&fit=crop&q=80&fm=webp 1024w, https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=1920&h=1080&fit=crop&q=80&fm=webp 1920w"
      sizes="(max-width: 640px) 640px, (max-width: 1024px) 1024px, 1920px"
      alt="Vitrier professionnel Paris Île-de-France - intervention rapide vitrerie"
      class="absolute inset-0 w-full h-full object-cover"
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Blue overlay for readability — warm & reassuring -->
    <div class="absolute inset-0 bg-gradient-to-r from-[#1A2B4A]/90 via-[#1A2B4A]/80 to-[#1A2B4A]/60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#1A2B4A]/70 via-[#1A2B4A]/50 to-[#1A2B4A]/40"></div>
    <div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-[#FAFBFD] to-transparent"></div>
    <!-- Glow effects -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-accent-500/5 rounded-full blur-3xl"></div>

    <div class="relative container-custom section-padding !pt-16 !pb-20 md:!pt-24 md:!pb-28">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left content -->
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/15 border border-white/20 backdrop-blur-sm rounded-full mb-6" style="animation: fade-in 0.6s ease-out">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-400"></span>
            </span>
            <span class="text-sm font-medium text-gray-200">Intervention rapide 24h/24 &mdash; 7j/7</span>
          </div>

          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-4 text-white" style="animation: fade-in-up 0.6s ease-out 0.1s both">
            Votre <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-200 to-accent-400">vitrier professionnel</span> en Île-de-France
          </h1>

          <p class="text-lg text-accent-300 font-semibold mb-4 italic" style="animation: fade-in-up 0.6s ease-out 0.15s both">
            {contactInfo.tagline}
          </p>

          <p class="text-lg md:text-xl text-gray-300 leading-relaxed mb-8 max-w-xl" style="animation: fade-in-up 0.6s ease-out 0.2s both">
            {contactInfo.companyName} vous accompagne pour tous vos travaux de vitrerie, miroiterie et dépannage urgent. Artisans qualifiés, tarifs transparents, intervention sur Paris et toute l'Île-de-France.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-3 mb-10" style="animation: fade-in-up 0.6s ease-out 0.3s both">
            <a href={contactInfo.phoneHref} class="btn-accent !py-3.5 shadow-xl shadow-accent-500/15">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              {contactInfo.phone}
            </a>
            <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="btn-whatsapp !py-3.5 shadow-xl shadow-green-600/15">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <a href="/services" class="btn-secondary !py-3.5 !text-white !border-white/30 hover:!bg-white/10">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
              Nos services
            </a>
          </div>

          <!-- Trust badges -->
          <div class="flex flex-wrap gap-3" style="animation: fade-in-up 0.6s ease-out 0.4s both">
            <div class="flex items-center gap-2 text-sm text-white font-medium bg-white/15 backdrop-blur-sm px-3 py-1.5 rounded-full">
              <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Devis gratuit
            </div>
            <div class="flex items-center gap-2 text-sm text-white font-medium bg-white/15 backdrop-blur-sm px-3 py-1.5 rounded-full">
              <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Sans engagement
            </div>
            <div class="flex items-center gap-2 text-sm text-white font-medium bg-white/15 backdrop-blur-sm px-3 py-1.5 rounded-full">
              <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              Agréé assurances
            </div>
          </div>
        </div>

        <!-- Right side: Stats -->
        <div class="hidden lg:block" style="animation: fade-in 0.8s ease-out 0.4s both">
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/15">
              <div class="text-4xl font-black text-white mb-1">24/7</div>
              <div class="text-gray-300 text-sm">Service d'urgence disponible jour et nuit</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/15">
              <div class="text-4xl font-black text-white mb-1">&lt;1h</div>
              <div class="text-gray-300 text-sm">Temps d'intervention moyen sur Paris</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/15">
              <div class="text-4xl font-black text-white mb-1">15+</div>
              <div class="text-gray-300 text-sm">Années d'expérience en vitrerie</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-6 border border-white/15">
              <div class="text-4xl font-black text-white mb-1">5000+</div>
              <div class="text-gray-300 text-sm">Interventions réalisées en IDF</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Présentation de l'entreprise -->
  <section class="py-10 md:py-14 bg-[#F0F4F8] border-b border-[#DFE6EE]">
    <div class="container-custom px-4 md:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-[#1A2B4A] mb-4">Votre vitrier de confiance à Paris et en Île-de-France</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          <strong class="text-[#1A2B4A]">Artisan Francilien IDF</strong> est une entreprise de vitrerie, miroiterie et dépannage vitrage basée à Paris (75015) et intervenant sur l'ensemble de l'Île-de-France. Fondée en 2009, l'entreprise emploie une équipe de vitriers qualifiés qui réalise plus de 500 interventions par an. Ses trois domaines d'expertise sont : l'installation et le remplacement de <a href="/services/vitrerie-double-vitrage" class="text-primary-500 hover:text-primary-600 underline">double et triple vitrage</a>, la <a href="/services/miroiterie-verre-decoratif" class="text-primary-500 hover:text-primary-600 underline">miroiterie sur mesure et le verre décoratif</a>, et le <a href="/services/depannage-urgence-vitrage" class="text-primary-500 hover:text-primary-600 underline">dépannage d'urgence 24h/24</a>. Artisan Francilien IDF est couvert par une assurance responsabilité civile professionnelle et une garantie décennale.
        </p>
        <p class="text-slate-600 leading-relaxed">
          Nous intervenons dans tous les arrondissements de Paris ainsi que dans les départements 77, 78, 91, 92, 93, 94 et 95. Que ce soit pour un remplacement de vitre cassée, la pose de double vitrage, une intervention en urgence ou un projet de miroiterie décorative, nos artisans vitriers se déplacent rapidement avec tout le matériel nécessaire pour une intervention soignée et durable.
        </p>
      </div>
    </div>
  </section>

  <!-- Domains of Intervention -->
  <section class="section-padding bg-[#F0F4F8]" id="domaines">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-50 text-primary-700 rounded-full text-sm font-medium mb-4 border border-primary-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          Nos domaines d'intervention
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-[#1A2B4A] mb-3">Nos services de vitrerie et vitrage</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">De la vitrerie classique à la miroiterie décorative, en passant par le dépannage d'urgence, nous couvrons tous vos besoins en verre sur Paris et l'Île-de-France.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviceCategories.map((cat, index) => (
          <a href={`/services/${cat.slug}`} class:list={['animate-on-scroll hover-lift group cursor-pointer block rounded-2xl overflow-hidden border border-[#DFE6EE] bg-white shadow-sm transition-all duration-300', `delay-${(index + 1) * 100}`]}>
            <!-- Image area -->
            <div class="relative h-44 overflow-hidden">
              <img
                src={`${cat.image}${cat.image.includes('?') ? '&' : '?'}w=400&h=250&fit=crop&fm=webp`}
                srcset={`${cat.image}${cat.image.includes('?') ? '&' : '?'}w=320&h=200&fit=crop&fm=webp 320w, ${cat.image}${cat.image.includes('?') ? '&' : '?'}w=400&h=250&fit=crop&fm=webp 400w, ${cat.image}${cat.image.includes('?') ? '&' : '?'}w=600&h=375&fit=crop&fm=webp 600w`}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                alt={`${cat.name} - services de vitrerie Paris`}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                width="400"
                height="250"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#1A2B4A]/70 via-[#1A2B4A]/30 to-transparent"></div>
              <div class="absolute bottom-3 left-3 w-10 h-10 bg-white/20 backdrop-blur-sm rounded-xl flex items-center justify-center border border-white/20">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={cat.iconPath} />
                </svg>
              </div>
              <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-2.5 py-1 rounded-full border border-white/50">
                <span class="text-xs font-medium text-[#1A2B4A]">{cat.services.length} services</span>
              </div>
            </div>
            <!-- Content -->
            <div class="p-5">
              <h3 class="text-lg font-bold text-[#1A2B4A] mb-2 group-hover:text-primary-500 transition-colors">{cat.name}</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-4">{cat.description}</p>
              <div class="flex items-center gap-1 text-sm font-medium text-primary-500">
                <span>Voir {cat.name.toLowerCase()}</span>
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="animate-on-scroll text-center mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-accent-500/10 text-accent-600 rounded-full text-sm font-medium mb-4 border border-accent-500/20">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
          Nos engagements
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-[#1A2B4A] mb-3">Pourquoi choisir {contactInfo.companyName} ?</h2>
        <p class="text-slate-600 max-w-2xl mx-auto">Des professionnels qualifiés, un service réactif et des tarifs transparents pour tous vos projets de vitrerie.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="animate-on-scroll delay-100 text-center p-6 card-dark rounded-2xl">
          <div class="w-16 h-16 bg-primary-50 border border-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          </div>
          <p class="font-bold text-[#1A2B4A] mb-2">Intervention rapide</p>
          <p class="text-sm text-slate-600">Moins d'une heure sur Paris, 2h en Île-de-France. Disponible 24h/24 et 7j/7.</p>
        </div>

        <div class="animate-on-scroll delay-200 text-center p-6 card-dark rounded-2xl">
          <div class="w-16 h-16 bg-primary-50 border border-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          </div>
          <p class="font-bold text-[#1A2B4A] mb-2">Garantie qualité</p>
          <p class="text-sm text-slate-600">Vitrages certifiés, pose dans les règles de l'art. Garantie décennale sur toutes nos interventions.</p>
        </div>

        <div class="animate-on-scroll delay-300 text-center p-6 card-dark rounded-2xl">
          <div class="w-16 h-16 bg-primary-50 border border-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>
          </div>
          <p class="font-bold text-[#1A2B4A] mb-2">Tarifs transparents</p>
          <p class="text-sm text-slate-600">Devis gratuit et détaillé avant chaque intervention. Aucun frais caché, aucune surprise.</p>
        </div>

        <div class="animate-on-scroll delay-400 text-center p-6 card-dark rounded-2xl">
          <div class="w-16 h-16 bg-primary-50 border border-primary-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
          </div>
