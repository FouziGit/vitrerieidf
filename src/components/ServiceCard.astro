---
interface Props {
  title: string;
  description: string;
  price: string;
  icon?: string;
  delay?: string;
}

const { title, description, price, delay = '' } = Astro.props;
---

<div class:list={['animate-on-scroll hover-lift bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden group', delay]}>
  <!-- Image placeholder -->
  <div class="h-48 bg-gradient-to-br from-primary-100 via-primary-50 to-accent-400/10 flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-600/5 to-transparent"></div>
    <svg class="w-16 h-16 text-primary-300 group-hover:text-primary-400 transition-colors duration-300 group-hover:scale-110 transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
    </svg>
    <!-- Price badge -->
    <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1.5 rounded-full shadow-sm">
      <span class="text-sm font-bold text-primary-700">{price}</span>
    </div>
  </div>

  <div class="p-5">
    <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-primary-700 transition-colors">{title}</h3>
    <p class="text-sm text-gray-600 leading-relaxed line-clamp-4">{description}</p>
    <div class="mt-4 pt-3 border-t border-gray-50 flex items-center justify-between">
      <span class="text-primary-600 font-semibold text-sm">{price}</span>
      <a href="#contact" class="text-sm font-medium text-primary-600 hover:text-primary-800 flex items-center gap-1 transition-colors">
        Devis gratuit
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>
  </div>
</div>
