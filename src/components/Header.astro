---
import { contactInfo } from '../data/contact';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/services', label: 'Nos services' },
  { href: '/entreprises', label: 'Entreprises' },
  { href: '/qui-sommes-nous', label: 'Qui sommes-nous' },
];
---

<!-- Urgency Top Bar — bleu rassurant -->
<div class="bg-primary-600 text-white text-sm py-2 px-4">
  <div class="container-custom flex items-center justify-between gap-4">
    <div class="flex items-center gap-2">
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-400"></span>
      </span>
      <span class="hidden sm:inline font-medium">Intervention rapide 24h/24 - 7j/7</span>
      <span class="sm:hidden font-medium">Urgence 24h/24</span>
    </div>
    <div class="flex items-center gap-3 sm:gap-4">
      <a href={contactInfo.phoneHref} class="flex items-center gap-1.5 hover:text-accent-300 transition-colors font-semibold text-white">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        <span>{contactInfo.phone}</span>
      </a>
      <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="hidden sm:flex items-center gap-1.5 hover:text-green-300 transition-colors" aria-label="WhatsApp">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </a>
      <a href={contactInfo.emailHref} class="hidden sm:flex items-center gap-1.5 hover:text-primary-200 transition-colors" aria-label="Email">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
      </a>
    </div>
  </div>
</div>

<!-- Main Navigation — light glass -->
<header class="sticky top-0 z-50 glass-dark border-b border-slate-200/80">
  <div class="container-custom">
    <nav class="flex items-center justify-between h-16 md:h-18 px-4 md:px-6 lg:px-8" aria-label="Navigation principale">
      <a href="/" class="flex items-center gap-3 group shrink-0" aria-label="Artisan Francilien IDF - Accueil">
        <img src="/images/logo.svg" alt="Artisan Francilien IDF" class="h-10 md:h-12 w-auto" />
      </a>

      <div class="hidden md:flex items-center gap-1">
        {navLinks.map(({ href, label }) => (
          <a href={href} class:list={['px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200', currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'bg-primary-50 text-primary-700' : 'text-slate-600 hover:text-primary-600 hover:bg-slate-100']}>
            {label}
          </a>
        ))}
      </div>

      <div class="hidden md:flex items-center gap-3">
        <a href={contactInfo.phoneHref} class="btn-accent text-sm !py-2.5 !px-5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          Appeler
        </a>
      </div>

      <button id="mobile-menu-btn" class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-slate-500 hover:bg-slate-100 transition-colors" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </nav>

    <div id="mobile-menu" class="hidden md:hidden pb-4 px-4">
      <div class="flex flex-col gap-1">
        {navLinks.map(({ href, label }) => (
          <a href={href} class:list={['px-4 py-3 rounded-lg text-sm font-medium transition-colors', currentPath === href || (href !== '/' && currentPath.startsWith(href)) ? 'bg-primary-50 text-primary-700' : 'text-slate-600 hover:bg-slate-100 hover:text-primary-600']}>
            {label}
          </a>
        ))}
        <div class="mt-2 pt-2 border-t border-slate-200 flex flex-col gap-2">
          <a href={contactInfo.phoneHref} class="btn-accent text-sm justify-center">Appeler maintenant</a>
          <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="btn-whatsapp text-sm justify-center">WhatsApp</a>
        </div>
      </div>
    </div>
  </div>
</header>
