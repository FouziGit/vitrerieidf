---
import { contactInfo } from '../data/contact';
---

<section id="contact" class="section-padding bg-[#F0F4F8]">
  <div class="container-custom">
    <div class="animate-on-scroll text-center mb-10">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-50 text-primary-700 rounded-full text-sm font-medium mb-4 border border-primary-200">Contactez-nous</span>
      <h2 class="text-3xl md:text-4xl font-bold text-[#1A2B4A] mb-3">Demandez votre devis gratuit</h2>
      <p class="text-slate-600 max-w-2xl mx-auto">Réponse sous 2 heures en moyenne. Nos experts vous accompagnent de A à Z.</p>
    </div>
    <div class="grid lg:grid-cols-5 gap-8 max-w-6xl mx-auto">
      <div class="lg:col-span-2 animate-on-scroll">
        <div class="bg-white rounded-2xl p-6 md:p-8 h-full border border-[#DFE6EE] shadow-sm">
          <h3 class="text-xl font-bold text-[#1A2B4A] mb-6">Contact direct</h3>
          <div class="space-y-4">
            <a href={contactInfo.phoneHref} class="flex items-center gap-4 p-3 rounded-xl bg-slate-50 hover:bg-primary-50 transition-colors">
              <div class="w-12 h-12 bg-accent-500/15 rounded-xl flex items-center justify-center shrink-0"><svg class="w-6 h-6 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg></div>
              <div><div class="text-sm text-slate-500">Téléphone</div><div class="font-semibold text-[#1A2B4A]">{contactInfo.phone}</div></div>
            </a>
            <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="flex items-center gap-4 p-3 rounded-xl bg-slate-50 hover:bg-green-50 transition-colors">
              <div class="w-12 h-12 bg-green-500/15 rounded-xl flex items-center justify-center shrink-0"><svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></div>
              <div><div class="text-sm text-slate-500">WhatsApp</div><div class="font-semibold text-[#1A2B4A]">Envoyez un message</div></div>
            </a>
            <a id="contact-email-link" href="#" class="flex items-center gap-4 p-3 rounded-xl bg-slate-50 hover:bg-primary-50 transition-colors">
              <div class="w-12 h-12 bg-primary-500/15 rounded-xl flex items-center justify-center shrink-0"><svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg></div>
              <div><div class="text-sm text-slate-500">Email</div><div id="contact-email-text" class="font-semibold text-[#1A2B4A] text-sm">Chargement...</div></div>
            </a>
          </div>
          <div class="mt-6 pt-5 border-t border-slate-200">
            <p class="text-sm text-slate-500"><strong class="text-slate-700">{contactInfo.hours}</strong><br/>{contactInfo.hoursOffice}</p>
          </div>
        </div>
      </div>
      <div class="lg:col-span-3 animate-on-scroll delay-200">
        <form id="contact-form" class="bg-white rounded-2xl p-6 md:p-8 border border-[#DFE6EE] shadow-sm">
          <!-- Feedback messages -->
          <div id="form-success" class="hidden mb-5 p-4 rounded-xl bg-green-50 border border-green-200">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div>
                <p class="font-semibold text-green-800">Message envoyé avec succès !</p>
                <p class="text-sm text-green-600">Nous vous répondrons sous 2 heures en jours ouvrés.</p>
              </div>
            </div>
          </div>
          <div id="form-error" class="hidden mb-5 p-4 rounded-xl bg-red-50 border border-red-200">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
              </div>
              <div>
                <p class="font-semibold text-red-800">Erreur lors de l'envoi</p>
                <p id="form-error-message" class="text-sm text-red-600">Veuillez réessayer ou nous contacter directement par téléphone.</p>
              </div>
            </div>
          </div>

          <div id="form-fields">
            <div class="grid sm:grid-cols-2 gap-4 mb-4">
              <div><label for="c-name" class="block text-sm font-medium text-slate-700 mb-1.5">Nom complet *</label><input type="text" id="c-name" name="name" required class="w-full px-4 py-2.5 rounded-xl bg-[#F7F9FC] border border-slate-300 text-slate-900 placeholder-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm" placeholder="Jean Dupont" /></div>
              <div><label for="c-email" class="block text-sm font-medium text-slate-700 mb-1.5">Email *</label><input type="email" id="c-email" name="email" required class="w-full px-4 py-2.5 rounded-xl bg-[#F7F9FC] border border-slate-300 text-slate-900 placeholder-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm" placeholder="jean@exemple.fr" /></div>
            </div>
            <div class="grid sm:grid-cols-2 gap-4 mb-4">
              <div><label for="c-phone" class="block text-sm font-medium text-slate-700 mb-1.5">Téléphone</label><input type="tel" id="c-phone" name="phone" class="w-full px-4 py-2.5 rounded-xl bg-[#F7F9FC] border border-slate-300 text-slate-900 placeholder-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm" placeholder="06 12 34 56 78" /></div>
              <div><label for="c-subject" class="block text-sm font-medium text-slate-700 mb-1.5">Motif *</label><select id="c-subject" name="subject" required class="w-full px-4 py-2.5 rounded-xl bg-[#F7F9FC] border border-slate-300 text-slate-900 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm"><option value="">Sélectionnez un motif</option><option value="Demande de devis">Demande de devis</option><option value="Demande d'informations">Demande d'informations</option><option value="Collaboration / Partenariat">Collaboration / Partenariat</option><option value="Urgence vitrage">Urgence vitrage</option></select></div>
            </div>
            <div class="mb-5"><label for="c-message" class="block text-sm font-medium text-slate-700 mb-1.5">Message *</label><textarea id="c-message" name="message" rows="4" required class="w-full px-4 py-2.5 rounded-xl bg-[#F7F9FC] border border-slate-300 text-slate-900 placeholder-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm resize-none" placeholder="Décrivez votre projet ou votre besoin..."></textarea></div>
            <button type="submit" id="submit-btn" class="btn-accent w-full text-base">
              <svg id="send-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
              <svg id="loading-icon" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
              <span id="btn-text">Envoyer ma demande</span>
            </button>
            <p class="text-xs text-slate-500 text-center mt-3">Réponse garantie sous 2h en jours ouvrés.</p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Email obfuscation
  (function(){
    var u='contact';var d='monartisanidf.fr';
    var el=document.getElementById('contact-email-link');
    var tx=document.getElementById('contact-email-text');
    if(el&&tx){el.href='mai'+'lto:'+u+'@'+d;tx.textContent=u+'@'+d;}
  })();

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formFields = document.getElementById('form-fields')!;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;
  const errorText = document.getElementById('form-error-message')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const sendIcon = document.getElementById('send-icon')!;
  const loadingIcon = document.getElementById('loading-icon')!;
  const btnText = document.getElementById('btn-text')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Hide previous messages
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    // Show loading state
    submitBtn.disabled = true;
    sendIcon.classList.add('hidden');
    loadingIcon.classList.remove('hidden');
    btnText.textContent = 'Envoi en cours...';

    const data = {
      name: (document.getElementById('c-name') as HTMLInputElement).value.trim(),
      email: (document.getElementById('c-email') as HTMLInputElement).value.trim(),
      phone: (document.getElementById('c-phone') as HTMLInputElement).value.trim(),
      subject: (document.getElementById('c-subject') as HTMLSelectElement).value,
      message: (document.getElementById('c-message') as HTMLTextAreaElement).value.trim(),
    };

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok) {
        successMsg.classList.remove('hidden');
        formFields.classList.add('hidden');
      } else {
        errorMsg.classList.remove('hidden');
        errorText.textContent = result.error || 'Veuillez réessayer ou nous contacter directement par téléphone.';
      }
    } catch {
      errorMsg.classList.remove('hidden');
      errorText.textContent = 'Erreur de connexion. Vérifiez votre connexion internet et réessayez.';
    } finally {
      // Reset button
      submitBtn.disabled = false;
      sendIcon.classList.remove('hidden');
      loadingIcon.classList.add('hidden');
      btnText.textContent = 'Envoyer ma demande';
    }
  });
</script>
