---
import { contactInfo } from '../data/contact';
---

<section id="contact" class="section-padding bg-dark-800">
  <div class="container-custom">
    <div class="animate-on-scroll text-center mb-10">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-900/50 text-primary-300 rounded-full text-sm font-medium mb-4 border border-primary-800/50">Contactez-nous</span>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Demandez votre devis gratuit</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">Réponse sous 2 heures en moyenne. Nos experts vous accompagnent de A à Z.</p>
    </div>
    <div class="grid lg:grid-cols-5 gap-8 max-w-6xl mx-auto">
      <div class="lg:col-span-2 animate-on-scroll">
        <div class="bg-dark-700 rounded-2xl p-6 md:p-8 h-full border border-white/5">
          <h3 class="text-xl font-bold text-white mb-6">Contact direct</h3>
          <div class="space-y-4">
            <a href={contactInfo.phoneHref} class="flex items-center gap-4 p-3 rounded-xl bg-white/5 hover:bg-white/8 transition-colors">
              <div class="w-12 h-12 bg-accent-500/20 rounded-xl flex items-center justify-center shrink-0"><svg class="w-6 h-6 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg></div>
              <div><div class="text-sm text-gray-500">Téléphone</div><div class="font-semibold text-white">{contactInfo.phone}</div></div>
            </a>
            <a href={contactInfo.whatsapp} target="_blank" rel="noopener" class="flex items-center gap-4 p-3 rounded-xl bg-white/5 hover:bg-white/8 transition-colors">
              <div class="w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center shrink-0"><svg class="w-6 h-6 text-green-400" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></div>
              <div><div class="text-sm text-gray-500">WhatsApp</div><div class="font-semibold text-white">Envoyez un message</div></div>
            </a>
            <a href={contactInfo.emailHref} class="flex items-center gap-4 p-3 rounded-xl bg-white/5 hover:bg-white/8 transition-colors">
              <div class="w-12 h-12 bg-primary-500/20 rounded-xl flex items-center justify-center shrink-0"><svg class="w-6 h-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg></div>
              <div><div class="text-sm text-gray-500">Email</div><div class="font-semibold text-white text-sm">{contactInfo.email}</div></div>
            </a>
          </div>
          <div class="mt-6 pt-5 border-t border-white/5">
            <p class="text-sm text-gray-500"><strong class="text-gray-300">{contactInfo.hours}</strong><br/>{contactInfo.hoursOffice}</p>
          </div>
        </div>
      </div>
      <div class="lg:col-span-3 animate-on-scroll delay-200">
        <form class="bg-dark-700 rounded-2xl p-6 md:p-8 border border-white/5">
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div><label for="c-name" class="block text-sm font-medium text-gray-300 mb-1.5">Nom complet *</label><input type="text" id="c-name" name="name" required class="w-full px-4 py-2.5 rounded-xl bg-dark-600 border border-white/10 text-white placeholder-gray-500 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm" placeholder="Jean Dupont" /></div>
            <div><label for="c-email" class="block text-sm font-medium text-gray-300 mb-1.5">Email *</label><input type="email" id="c-email" name="email" required class="w-full px-4 py-2.5 rounded-xl bg-dark-600 border border-white/10 text-white placeholder-gray-500 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm" placeholder="jean@exemple.fr" /></div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4 mb-4">
            <div><label for="c-phone" class="block text-sm font-medium text-gray-300 mb-1.5">Téléphone</label><input type="tel" id="c-phone" name="phone" class="w-full px-4 py-2.5 rounded-xl bg-dark-600 border border-white/10 text-white placeholder-gray-500 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm" placeholder="06 12 34 56 78" /></div>
            <div><label for="c-subject" class="block text-sm font-medium text-gray-300 mb-1.5">Motif *</label><select id="c-subject" name="subject" required class="w-full px-4 py-2.5 rounded-xl bg-dark-600 border border-white/10 text-white focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm"><option value="">Sélectionnez un motif</option><option value="devis">Demande de devis</option><option value="info">Demande d'informations</option><option value="collaboration">Collaboration / Partenariat</option><option value="urgence">Urgence vitrage</option></select></div>
          </div>
          <div class="mb-5"><label for="c-message" class="block text-sm font-medium text-gray-300 mb-1.5">Message *</label><textarea id="c-message" name="message" rows="4" required class="w-full px-4 py-2.5 rounded-xl bg-dark-600 border border-white/10 text-white placeholder-gray-500 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-sm resize-none" placeholder="Décrivez votre projet ou votre besoin..."></textarea></div>
          <button type="submit" class="btn-accent w-full text-base"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>Envoyer ma demande</button>
          <p class="text-xs text-gray-600 text-center mt-3">Réponse garantie sous 2h en jours ouvrés.</p>
        </form>
      </div>
    </div>
  </div>
</section>
