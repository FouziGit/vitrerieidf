---
import { faqItems } from '../data/services';
---

<section class="section-padding bg-dark-900" id="faq">
  <div class="container-custom max-w-4xl">
    <div class="animate-on-scroll text-center mb-10">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary-900/50 text-primary-300 rounded-full text-sm font-medium mb-4 border border-primary-800/50">FAQ</span>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-3">Questions fréquentes</h2>
      <p class="text-gray-400">Retrouvez les réponses aux questions les plus posées par nos clients.</p>
    </div>
    <div class="space-y-3">
      {faqItems.map((item, index) => (
        <div class:list={['animate-on-scroll', `delay-${Math.min((index + 1) * 100, 500)}`]}>
          <details class="group card-dark rounded-xl transition-colors">
            <summary class="flex items-center justify-between gap-4 cursor-pointer px-5 py-4 text-left">
              <h3 class="font-medium text-gray-200 group-open:text-accent-400 transition-colors">{item.question}</h3>
              <svg class="w-5 h-5 shrink-0 text-gray-500 group-open:text-accent-400 group-open:rotate-180 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-gray-400 leading-relaxed">{item.answer}</div>
          </details>
        </div>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer }
  }))
})} />
