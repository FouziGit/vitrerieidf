---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { contactInfo } from '../data/contact';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  jsonLd?: object | object[];
}

const { title, description, canonical, jsonLd } = Astro.props;
const siteUrl = 'https://www.artisan-francilien-idf.fr';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
const ogImage = `${siteUrl}/images/og-default.jpg`;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <link rel="canonical" href={fullCanonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content={contactInfo.companyName} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Geo targeting -->
  <meta name="geo.region" content="FR-IDF" />
  <meta name="geo.placename" content="Paris" />

  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schema.org Organization + LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
    "@id": `${siteUrl}/#organization`,
    "name": contactInfo.companyName,
    "alternateName": "Artisan Francilien IDF",
    "description": "Artisan vitrier professionnel en Île-de-France spécialisé dans le double vitrage, la miroiterie sur mesure et le dépannage d'urgence 24h/24. Plus de 15 ans d'expérience et 5 000 interventions réalisées à Paris et en Île-de-France.",
    "url": siteUrl,
    "telephone": "+33184800000",
    "email": contactInfo.email,
    "logo": `${siteUrl}/images/logo.svg`,
    "image": ogImage,
    "foundingDate": "2009",
    "numberOfEmployees": { "@type": "QuantitativeValue", "minValue": 10, "maxValue": 20 },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "12 Rue de la Verrerie",
      "addressLocality": "Paris",
      "postalCode": "75004",
      "addressRegion": "Île-de-France",
      "addressCountry": "FR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 48.8566,
      "longitude": 2.3522
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "19:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "09:00",
        "closes": "17:00"
      }
    ],
    "areaServed": [
      { "@type": "City", "name": "Paris", "sameAs": "https://fr.wikipedia.org/wiki/Paris" },
      { "@type": "State", "name": "Île-de-France", "sameAs": "https://fr.wikipedia.org/wiki/%C3%8Ele-de-France" }
    ],
    "serviceArea": {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 48.8566, "longitude": 2.3522 },
      "geoRadius": "80000"
    },
    "priceRange": "€€",
    "paymentAccepted": ["Cash", "Credit Card", "Bank Transfer", "Check"],
    "currenciesAccepted": "EUR",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Services de vitrerie",
      "itemListElement": [
        { "@type": "OfferCatalog", "name": "Vitrerie & double vitrage" },
        { "@type": "OfferCatalog", "name": "Miroiterie & verre décoratif" },
        { "@type": "OfferCatalog", "name": "Dépannage & urgence vitrage" }
      ]
    },
    "sameAs": []
  })} />

  <!-- Schema.org WebSite -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": contactInfo.companyName,
    "url": siteUrl,
    "description": "Artisan vitrier professionnel à Paris et en Île-de-France. Vitrerie, miroiterie sur mesure, dépannage urgence 24h/24.",
    "inLanguage": "fr-FR",
    "publisher": { "@id": `${siteUrl}/#organization` }
  })} />

  {/* Page-specific JSON-LD */}
  {jsonLd && (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body class="min-h-screen flex flex-col">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent-500 focus:text-dark-950 focus:rounded-lg focus:font-semibold">Aller au contenu principal</a>
  <Header />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer />

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );
    document.querySelectorAll('.animate-on-scroll').forEach((el) => observer.observe(el));

    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
    }
  </script>
</body>
</html>
